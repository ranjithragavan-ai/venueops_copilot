# This is an example of the environment variables required to run VenueOps Copilot in live production mode.
# If these are not provided, the application will gracefully fall back to the mock JSON database.

# Your Gemini API Key from Google AI Studio
GEMINI_API_KEY="AIzaSyYourGeminiApiKeyGoesHere..."

# Set to False to enforce live Firebase connection (or True to force offline testing mode)
USE_MOCK_DB="False"

# The path to your Firebase service account JSON file
FIREBASE_CREDENTIALS_PATH="./secrets/firebase-service-account.json"
